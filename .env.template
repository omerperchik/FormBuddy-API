# Server
PORT=3500
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/formbuddy

# Auth
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Encryption (supports key rotation — set ENCRYPTION_KEY_NEXT to rotate)
ENCRYPTION_KEY=your-32-byte-hex-key-here
# ENCRYPTION_KEY_NEXT=new-key-for-rotation

# Anthropic (field classification)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Stripe (billing)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_YEARLY=price_xxx

# CORS
ALLOWED_ORIGINS=chrome-extension://xxx,http://localhost:3000
